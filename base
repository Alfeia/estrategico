def parse_args(argv: Optional[list[str]] = None) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="ETL Indicadores KRI - Petros (Excel → SQLite).",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    p.add_argument(
        "--meses", nargs="+", metavar="MÊS", choices=list(MESES.keys()),
        help="Meses a processar (padrão: todos).",
    )
    p.add_argument("--pasta", type=Path, help="Pasta das planilhas (override).")
    p.add_argument("--db", type=Path, help="Caminho do banco SQLite (override).")
    p.add_argument("--no-backup", action="store_true", help="Não fazer backup do banco.")
    p.add_argument("--dry-run", action="store_true",
                   help="Processa e valida, mas NÃO grava no banco.")
    p.add_argument("-v", "--verbose", action="store_true", help="Log detalhado (debug).")
    return p.parse_args(argv)


# ==============================================================================
# 15. EXECUÇÃO
# ==============================================================================
def main(argv: Optional[list[str]] = None) -> int:
    global PASTA_BASES, CAMINHO_DB
    args = parse_args(argv)
    configurar_logging(args.verbose)

    if args.pasta:
        PASTA_BASES = args.pasta
    if args.db:
        CAMINHO_DB = args.db

    meses = {m: MESES[m] for m in args.meses} if args.meses else dict(MESES)

    log.info("=" * 60)
    log.info("🚀 ETL INDICADORES KRI - PETROS")
    log.info("=" * 60)
    log.info(f"📁 Pasta : {PASTA_BASES}")
    log.info(f"🗃️  Banco : {CAMINHO_DB}")
    log.info(f"📅 Meses : {', '.join(meses)}")
    if args.dry_run:
        log.info("🧪 MODO DRY-RUN — nada será gravado.")

    if not PASTA_BASES.exists():
        log.error(f"❌ Pasta de bases não existe: {PASTA_BASES}")
        return 2

    if not args.dry_run and not args.no_backup:
        fazer_backup()

    indicadores, detalhes, farol, retorno, justificativas = processar_tudo(meses)

    log.info("\n" + "=" * 60)
    log.info("📊 RESUMO")
    log.info("=" * 60)
    log.info(f"   Indicadores:       {len(indicadores)} linhas")
    log.info(f"   Detalhes solv.:    {len(detalhes)} linhas")
    log.info(f"   Farol:             {len(farol)} linhas")
    log.info(f"   Retorno (jan/fev): {len(retorno)} linhas")
    log.info(f"   Justificativas:    {len(justificativas)} linhas")

    # Qualidade dos dados
    avisos = validar_dados(indicadores, farol)
    if avisos:
        log.info("\n🔎 QUALIDADE DOS DADOS:")
        for a in avisos:
            log.warning(f"   ⚠️  {a}")
    else:
        log.info("\n🔎 Qualidade: nenhum problema detectado. 👍")

    if not (indicadores or detalhes or farol or retorno or justificativas):
        log.error("\n❌ Nada foi processado — verifique a pasta e os nomes dos arquivos.")
        return 1

    if args.dry_run:
        log.info("\n🧪 Dry-run concluído — banco NÃO foi alterado.")
        return 0

    gravar_no_banco(indicadores, detalhes, farol, retorno, justificativas, meses)
    log.info("\n🎉 ETL concluído com sucesso!")
    return 0


if __name__ == "__main__":
    sys.exit(main())
