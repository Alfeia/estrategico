# 11. LOOP PRINCIPAL
# ==============================================================================
def processar_tudo(meses: dict[str, str]):
    todos_indicadores = []
    todos_detalhes    = []
    todos_farol       = []
    todos_retorno     = []
    todas_justificativas = []

    for mes, competencia in meses.items():
        nome_ind = f"Indicadores {mes}.xlsx"
        nome_jus = f"justificativas {mes}.xlsx"
        path_ind = PASTA_BASES / nome_ind
        path_jus = PASTA_BASES / nome_jus

        if not path_ind.exists():
            log.warning(f"❌ Arquivo não encontrado: {nome_ind}")
            continue

        log.info(f"\n📂 Processando {mes.upper()}...")

        # Lê todas as abas do Indicadores
        try:
            abas = pd.read_excel(path_ind, sheet_name=None, engine="openpyxl", header=None)
        except Exception as e:
            log.error(f"   ❌ Falha ao abrir {nome_ind}: {e}")
            continue

        for nome_aba, df in abas.items():
            aba_limpa = nome_aba.strip()

            if aba_limpa == "1-Desequilíbrio Atuarial":
                ind, det = ler_bloco_1(df, competencia, nome_ind)
                todos_indicadores.extend(ind)
                todos_detalhes.extend(det)
                log.info(f"   ✅ Bloco 1: {len(ind)} indicadores")

            elif aba_limpa.startswith("2-"):
                ind = ler_bloco_padrao(df, "2-Legal, Regulatório e Governança", competencia, nome_ind)
                todos_indicadores.extend(ind)
                log.info(f"   ✅ Bloco 2: {len(ind)} indicadores")

            elif aba_limpa.startswith("3 -") or aba_limpa.startswith("3-"):
                ind = ler_bloco_padrao(df, "3-Cibernético e Tecnologia", competencia, nome_ind)
                todos_indicadores.extend(ind)
                log.info(f"   ✅ Bloco 3: {len(ind)} indicadores")

            elif aba_limpa.startswith("4-"):
                ind = ler_bloco_padrao(df, "4-Ineficiência Operacional", competencia, nome_ind)
                todos_indicadores.extend(ind)
                log.info(f"   ✅ Bloco 4: {len(ind)} indicadores")

            elif "farol" in aba_limpa.lower() or "planilha2" in aba_limpa.lower():
                f = ler_farol(df, competencia, nome_ind)
                todos_farol.extend(f)
                log.info(f"   ✅ Farol: {len(f)} linhas")

            elif aba_limpa.lower() == "planilha1":
                r = ler_retorno_nao_equacionar(df, competencia, nome_ind)
                todos_retorno.extend(r)
                log.info(f"   ✅ Retorno: {len(r)} linhas")

        # Justificativas
        j = ler_justificativas(path_jus, competencia, nome_jus)
        todas_justificativas.extend(j)
        log.info(f"   ✅ Justificativas: {len(j)} linhas")

    return todos_indicadores, todos_detalhes, todos_farol, todos_retorno, todas_justificativas


# ==============================================================================
# 12. VALIDAÇÃO / QUALIDADE DOS DADOS
# ==============================================================================
def validar_dados(indicadores, farol) -> list[str]:
    """Checagens leves de sanidade. Retorna lista de avisos (não interrompe)."""
    avisos: list[str] = []

    # Indicadores sem nota final
    sem_nota = [i for i in indicadores if i["nota_final"] is None]
    if sem_nota:
        avisos.append(f"{len(sem_nota)} indicador(es) sem nota_final.")

    # Notas fora da faixa esperada (0–10)
    fora = [i for i in indicadores
            if i["nota_final"] is not None and not (0 <= i["nota_final"] <= 10)]
    if fora:
        avisos.append(f"{len(fora)} indicador(es) com nota_final fora de 0–10.")

    # Duplicidade (competencia + bloco + item)
    vistos = set()
    dups = 0
    for i in indicadores:
        chave = (i["competencia"], i["bloco_risco"], i["item"])
        if chave in vistos:
            dups += 1
        vistos.add(chave)
    if dups:
        avisos.append(f"{dups} indicador(es) duplicado(s) (competência+bloco+item).")

    # Farol sem valor de farol
    farol_vazio = [f for f in farol if f["farol"] is None]
    if farol_vazio:
        avisos.append(f"{len(farol_vazio)} linha(s) de farol sem valor de farol.")

    return avisos


# ==============================================================================
# 13. GRAVAÇÃO NO BANCO (transação atômica)
# ==============================================================================
def _inserir(cur: sqlite3.Cursor, tabela: str, dados: list[dict]) -> int:
    """Insert em lote (executemany) dentro da transação corrente."""
    if not dados:
        log.info(f"   ⚠️  Sem dados pra {tabela}")
        return 0
    colunas = list(dados[0].keys())
    placeholders = ",".join(["?"] * len(colunas))
    sql = f"INSERT INTO {tabela} ({','.join(colunas)}) VALUES ({placeholders})"
    valores = [tuple(linha.get(c) for c in colunas) for linha in dados]
    cur.executemany(sql, valores)
    log.info(f"   ✅ {tabela}: {len(valores)} linhas inseridas")
    return len(valores)


def gravar_no_banco(indicadores, detalhes, farol, retorno, justificativas,
                    meses: dict[str, str]) -> None:
    """
    Recarrega de forma ATÔMICA as competências processadas:
    todo o delete + insert ocorre numa única transação. Qualquer erro
    faz rollback completo — nunca deixa o banco num estado parcial.
    """
    CAMINHO_DB.parent.mkdir(parents=True, exist_ok=True)

    tabelas = {
        "indicadores": indicadores,
        "desequilibrio_atuarial_detalhe": detalhes,
        "farol_consolidado": farol,
        "retorno_nao_equacionar": retorno,
        "justificativas_indicadores": justificativas,
    }

    competencias = list(meses.values())
    placeholders = ",".join(["?"] * len(competencias))

    with closing(sqlite3.connect(CAMINHO_DB)) as con:
        garantir_schema(con)
        try:
            cur = con.cursor()

            # 1) Limpa as competências que vamos recarregar
            for tabela in tabelas:
                cur.execute(
                    f"DELETE FROM {tabela} WHERE competencia IN ({placeholders})",
                    competencias,
                )
                log.info(f"🗑️  {tabela}: {cur.rowcount} linhas antigas removidas")

            # 2) Insere os dados novos
            log.info("\n💾 Inserindo dados novos...")
            for tabela, dados in tabelas.items():
                _inserir(cur, tabela, dados)

            con.commit()  # tudo ou nada
            log.info("✅ Transação confirmada (commit).")
        except Exception:
            con.rollback()
            log.error("❌ Erro na gravação — rollback executado, banco intacto.")
            raise


