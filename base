# 8. LEITURA DA ABA FAROL
# ==============================================================================
def ler_farol(df, competencia, arquivo):
    linhas = []
    for _, row in df.iterrows():
        nome = limpar_texto(row.iloc[0])
        if not nome or "RISCO" in str(nome).upper() or "LEGENDA" in str(nome).upper():
            continue
        if not any(c.isdigit() for c in str(nome)[:3]):
            continue

        linhas.append({
            "competencia":      competencia,
            "risco_estrategico":nome,
            "meta":             to_num(_cel(row, 1)),
            "real_mes_anterior":to_num(_cel(row, 2)),
            "real_mes_vigente": to_num(_cel(row, 3)),
            "farol":            to_num(_cel(row, 4)),
            "arquivo_origem":   arquivo,
            "data_carga":       DATA_CARGA,
        })
    return linhas


