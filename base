# 6. LEITURA DOS BLOCOS 2, 3, 4 (estrutura semelhante)
# ==============================================================================
def ler_bloco_padrao(df, bloco, competencia, arquivo):
    """
    Lê blocos 2, 3, 4 — colunas:
    item | fator_risco | resumo | risco | responsavel | pilares | metrica
    | memoria | polaridade | frequencia | peso_metrica | peso_indicador
    | resultado_mes | nota_final | comentario [| justificativa]
    """
    linhas = []
    for _, row in df.iterrows():
        item = row.iloc[0]
        # só linhas que têm número no item
        if pd.isna(item) or not str(item).strip().replace(".", "").isdigit():
            continue

        linhas.append({
            "competencia":            competencia,
            "bloco_risco":            bloco,
            "item":                   int(float(item)),
            "fator_risco":            limpar_texto(_cel(row, 1)),
            "resumo_fator_risco":     limpar_texto(_cel(row, 2)),
            "risco":                  limpar_texto(_cel(row, 3)),
            "responsavel":            limpar_texto(_cel(row, 4)),
            "pilares_estrategicos":   limpar_texto(_cel(row, 5)),
            "metrica":                limpar_texto(_cel(row, 6)),
            "memoria_calculo_meta":   limpar_texto(_cel(row, 7)),
            "polaridade":             limpar_texto(_cel(row, 8)),
            "frequencia_atualizacao": limpar_texto(_cel(row, 9)),
            "peso_metrica":           to_num(_cel(row, 10)),
            "peso_indicador":         to_num(_cel(row, 11)),
            "resultado_mes":          to_num(_cel(row, 12)),
            "nota_final":             to_num(_cel(row, 13)),
            "resultado_comentario":   limpar_texto(_cel(row, 14)),
            "arquivo_origem":         arquivo,
            "data_carga":             DATA_CARGA,
        })
    return linhas


