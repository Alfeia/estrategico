def garantir_schema(con: sqlite3.Connection) -> None:
    """Cria tabelas e índices se ainda não existirem (não altera dados)."""
    cur = con.cursor()
    for ddl in SCHEMA.values():
        cur.execute(ddl)
    for idx in INDICES:
        cur.execute(idx)
    log.debug("Schema garantido (tabelas + índices).")


# ==============================================================================
# 4. BACKUP DO BANCO (seguro + retenção)
# ==============================================================================
def fazer_backup() -> None:
    """Faz backup do .db. Ignora silenciosamente se ele ainda não existe."""
    if not CAMINHO_DB.exists():
        log.info("ℹ️  Banco ainda não existe — backup ignorado (primeira carga).")
        return

    carimbo = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup = CAMINHO_DB.with_name(f"{CAMINHO_DB.stem}_backup_{carimbo}.db")
    shutil.copy2(CAMINHO_DB, backup)
    log.info(f"🗄️  Backup criado: {backup.name}")
    _limpar_backups_antigos()


def _limpar_backups_antigos() -> None:
    """Mantém apenas os MAX_BACKUPS mais recentes."""
    padrao = f"{CAMINHO_DB.stem}_backup_*.db"
    backups = sorted(
        CAMINHO_DB.parent.glob(padrao),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    for antigo in backups[MAX_BACKUPS:]:
        try:
            antigo.unlink()
            log.debug(f"🧹 Backup antigo removido: {antigo.name}")
        except OSError:
            pass


# ==============================================================================
# 5. FUNÇÕES AUXILIARES
# ==============================================================================
def to_num(valor: Any) -> Optional[float]:
    """Converte texto/percentual em número (ou None)."""
    if pd.isna(valor):
        return None
    if isinstance(valor, (int, float)):
        return float(valor)
    s = str(valor).strip().replace("%", "").replace(",", ".")
    try:
        return float(s)
    except ValueError:
        return None


def limpar_texto(valor: Any) -> Optional[str]:
    """Remove espaços e quebras desnecessárias."""
    if pd.isna(valor):
        return None
    return str(valor).strip()


def _cel(row: pd.Series, i: int) -> Any:
    """Acesso seguro a uma célula da linha (None se a coluna não existe)."""
    return row.iloc[i] if len(row) > i else None


