def ler_retorno_nao_equacionar(df, competencia, arquivo):
    linhas = []
    for _, row in df.iterrows():
        plano = limpar_texto(row.iloc[0])
        retorno = to_num(_cel(row, 1))
        if not plano or plano.upper() == "PLANO" or retorno is None:
            continue
        linhas.append({
            "competencia":            competencia,
            "plano":                  plano,
            "retorno_nao_equacionar": retorno,
            "arquivo_origem":         arquivo,
            "data_carga":             DATA_CARGA,
