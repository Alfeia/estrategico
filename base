# 10. LEITURA DAS JUSTIFICATIVAS
# ==============================================================================
def ler_justificativas(arquivo_path, competencia, nome_arquivo):
    linhas = []
    if not Path(arquivo_path).exists():
        log.warning(f"   ⚠️  Justificativas não encontradas: {nome_arquivo}")
        return linhas
    try:
        abas = pd.read_excel(arquivo_path, sheet_name=None, engine="openpyxl", header=None)
    except Exception as e:  # arquivo corrompido / formato inesperado
        log.warning(f"   ⚠️  Erro lendo justificativas {nome_arquivo}: {e}")
        return linhas

    for nome_aba, df in abas.items():
        bloco = "3-Cibernético e Tecnologia" if "ciber" in nome_aba.lower() else "4-Ineficiência Operacional"
        # pula header (geralmente 2 primeiras linhas)
        for _, row in df.iloc[2:].iterrows():
            fator = limpar_texto(row.iloc[0])
            if not fator or "FATOR" in str(fator).upper() or "DESENQUADROU" in str(fator).upper():
                continue
            linhas.append({
                "competencia":   competencia,
                "bloco_risco":   bloco,
                "fator_risco":   fator,
                "metrica":       limpar_texto(_cel(row, 1)),
                "meta":          limpar_texto(_cel(row, 2)),
                "resultado":     limpar_texto(_cel(row, 3)),
                "justificativa": limpar_texto(_cel(row, 4)),
                "arquivo_origem":nome_arquivo,
                "data_carga":    DATA_CARGA,
            })
    return linhas


